# MongoDB Atlas Connection String
# Replace with your MongoDB Atlas URI (must be a replica set or Atlas cluster for Change Streams)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ordersdb?retryWrites=true&w=majority

# Port for the Express + WebSocket server
PORT=4000

# Allowed origins for CORS (comma-separated)
# For local dev: http://localhost:5173
# For production: https://your-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:5173
